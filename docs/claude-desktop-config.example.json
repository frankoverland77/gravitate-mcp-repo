{
  "mcpServers": {
    "excalibrr": {
      "command": "node",
      "args": ["/absolute/path/to/excalibrr-mcp-server/build/index.js"],
      "env": {
        "EXCALIBRR_PATH": "/absolute/path/to/excalibrr",
        "USAGE_EXAMPLES_PATH": "/absolute/path/to/your-main-project",
        "FIGMA_API_TOKEN": "your_figma_token_here"
      }
    }
  }
}
