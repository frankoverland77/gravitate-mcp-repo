# Excalibrr Demo Environment Variables
# Copy this file to .env.local and fill in the actual values

# AG Grid Enterprise License Key
# Get your license key from AG Grid
# Format: Using_this_AG_Grid_Enterprise_key_...
# Note: License expires December 17, 2024 - renew before then
VITE_AG_GRID_LICENSE_KEY=Using_this_AG_Grid_Enterprise_key_( AG-050987 )_in_excess_of_the_licence_granted_is_not_permitted___Please_report_misuse_to_( legal@ag-grid.com )___For_help_with_changing_this_key_please_contact_( info@ag-grid.com )___( capSpire )_is_granted_a_( Multiple Applications )_Developer_License_for_( 3 )_Front-End_JavaScript_developers___All_Front-End_JavaScript_developers_need_to_be_licensed_in_addition_to_the_ones_working_with_AG_Grid_Enterprise___This_key_has_been_granted_a_Deployment_License_Add-on_for_( 8 )_Production_Environments___This_key_works_with_AG_Grid_Enterprise_versions_released_before_( 17_December_2024 )____[v2]_MTczNDM5MzYwMDAwMA==97e04a13d661cd40e68a78abfaa164d0

# NPM Authentication Token
# Required for installing private @gravitate-js/excalibrr package
#
# For LOCAL development:
#   - Your personal token is already in ~/.npmrc
#   - You don't need to set this in .env.local
#
# For VERCEL deployment:
#   - Create a read-only granular access token at https://www.npmjs.com/settings/tokens
#   - Set NPM_TOKEN in Vercel Project Settings → Environment Variables
#   - Mark as "Sensitive" and enable for all environments
#   - Token should have read-only access to @gravitate-js organization
#
# Security: Never commit actual tokens to Git!
# NPM_TOKEN=npm_xxxxxxxxxxxxxxxxxxxxx
