{
  "name": "excalibrr-demo",
  "version": "1.0.2",
  "description": "Excalibrr Component Demo Project",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "pkill -f 'vite.*excalibrr-demo' || true && vite",
    "dev:check": "ps aux | grep vite | grep excalibrr-demo || echo 'No servers running'",
    "stop": "pkill -f 'vite.*excalibrr-demo' || true",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "quality:check": "yarn type-check && yarn lint && yarn format:check"
  },
  "dependencies": {
    "@gravitate-js/excalibrr": "4.0.34-osp",
    "@nivo/bar": "0.79.1",
    "@nivo/core": "0.79.0",
    "@nivo/line": "0.79.1",
    "@nivo/scatterplot": "^0.99.0",
    "@nivo/tooltip": "0.79.0",
    "@tanstack/react-query": "^4.10.3",
    "@types/leaflet": "^1.9.20",
    "ag-grid-community": "^30.2.1",
    "ag-grid-enterprise": "^30.2.1",
    "ag-grid-react": "^30.2.1",
    "antd": "4.20",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "moment": "^2.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-ga": "^3.3.1",
    "react-leaflet": "^4.0.0",
    "react-lottie": "^1.2.10",
    "react-router-dom": "^6.16.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "less": "^4.1.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^4.0.0"
  },
  "license": "ISC"
}
