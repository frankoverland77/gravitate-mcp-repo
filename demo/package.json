{
  "name": "excalibrr-demo",
  "version": "1.0.4",
  "description": "Excalibrr Component Demo Project",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "pkill -f 'vite.*excalibrr-demo' || true && vite",
    "dev:check": "ps aux | grep vite | grep excalibrr-demo || echo 'No servers running'",
    "stop": "pkill -f 'vite.*excalibrr-demo' || true",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:css": "stylelint \"src/**/*.{css,less}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,less}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "quality:check": "yarn type-check && yarn lint && yarn format:check",
    "check:pages": "node scripts/check-page-registration.cjs"
  },
  "dependencies": {
    "@ant-design/colors": "^7.1.0",
    "@ant-design/icons": "5.5.2",
    "@gravitate-js/excalibrr": "^5.2.0",
    "@nivo/bar": "0.79.1",
    "@nivo/core": "0.79.0",
    "@nivo/line": "0.79.1",
    "@nivo/scatterplot": "^0.99.0",
    "@nivo/tooltip": "0.79.0",
    "@react-hookz/web": "^23.1.0",
    "@tanstack/react-query": "^4.10.3",
    "@types/leaflet": "^1.9.20",
    "ag-grid-community": "^30.2.1",
    "ag-grid-enterprise": "^30.2.1",
    "ag-grid-react": "^30.2.1",
    "antd": "^5.23.0",
    "color": "^4.2.3",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "classnames": "^2.5.1",
    "file-saver": "^2.0.5",
    "google-map-react": "^2.1.10",
    "lodash": "^4.17.15",
    "lottie-react": "^2.4.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-ga": "^3.3.1",
    "react-leaflet": "^4.0.0",
    "react-lottie": "^1.2.10",
    "react-router-dom": "^6.16.0",
    "recharts": "^3.5.1",
    "zustand": "^5.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "less": "^4.1.0",
    "lint-staged": "^16.2.7",
    "postcss-less": "^6.0.0",
    "prettier": "^3.6.2",
    "stylelint": "^16.26.0",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.48.0",
    "vite": "7.1.11",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^4.0.0"
  },
  "license": "ISC",
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,json,md}": [
      "prettier --write"
    ]
  }
}
